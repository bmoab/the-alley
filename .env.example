# =====================================================================
# The Alley On Center — Environment Variables
# Copy this file to ".env" and fill in real values. Never commit .env.
# The app runs fully WITHOUT any of these set (demo/sandbox fallbacks).
# =====================================================================

# --- App ---
# Public base URL of the site (used in emails for links). Defaults to localhost.
APP_URL=http://localhost:3000

# Secret used to sign admin session cookies (JWT). CHANGE THIS in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=dev-insecure-change-me-please-0000000000000000

# --- Admin account (seeded on first run if no admin exists) ---
ADMIN_EMAIL=thealleyoncenter@gmail.com
ADMIN_PASSWORD=alley2024

# --- Square (sandbox) ---
# If absent, invoice creation is SIMULATED and logged to the console.
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox

# --- Email ---
# If no provider keys are set, emails are logged to the console instead of sent.
# Option A: Resend
RESEND_API_KEY=
# Option B: SMTP (e.g. Gmail) — used only if RESEND_API_KEY is empty
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# From-address and owner notification address
EMAIL_FROM="The Alley On Center <thealleyoncenter@gmail.com>"
OWNER_EMAIL=thealleyoncenter@gmail.com
